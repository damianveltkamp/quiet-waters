{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.quietwaters.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "Quiet Waters saves your wallpapers to Photos.",
          "savePhotosPermission": "Quiet Waters saves your wallpapers to Photos.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.quietwaters.app.widgets",
          "groupIdentifier": "group.com.quietwaters.app",
          "widgets": [
            {
              "name": "QuietWatersWidget",
              "displayName": "Daily Verse",
              "description": "A daily Bible verse on your home screen.",
              "ios": { "supportedFamilies": ["systemSmall", "systemMedium", "systemLarge"] }
            },
            {
              "name": "QuietWatersLockWidget",
              "displayName": "Daily Verse",
              "description": "A daily Bible verse on your lock screen.",
              "ios": { "supportedFamilies": ["accessoryRectangular"] }
            }
          ]
        }
      ]
    ],
    "extra": {
      "revenueCatIosKey": "test_zPnhwfAvZwCFKBftbZQlHbMewgd",
      "posthogKey": "phc_tvHD6K3pnZNfPJb8joUywX2gDbgaAZgaF6VuMeZkT5Vi",
      "posthogHost": "https://us.i.posthog.com"
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
